# Live data sources for the dashboard. Copy to .env.local for local dev,
# or set in Vercel → Project Settings → Environment Variables.
#
# Any unset variable falls back to mock data automatically. The dashboard
# shows a "Demo data" badge in the header when any source is missing.

# --- Shopify Admin GraphQL ---
# Required for: revenue today/yesterday, 7-day chart, top products, AOV, RTO,
# orders count, new customers count.
# Create a custom app in Shopify Admin → Apps → Develop apps → grant
# read_orders + read_products + read_customers + read_inventory scopes,
# install, copy Admin API access token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10

# --- Meta Marketing API ---
# Required for: ad spend, ROAS in-platform, CPM, CTR, top ad sets,
# campaign-level activity feed.
# Generate via Meta Business Settings → System Users → Add System User →
# generate token with ads_read + ads_management scopes (long-lived).
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_1234567890

# --- Notion (optional) ---
# Required for: festival calendar widget, activity feed (Daily Standup Log),
# launches list. Create an internal integration at notion.so/my-integrations,
# share the parent "Dropshipping Ops" page with it, copy DB IDs from URLs.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_FESTIVAL_CALENDAR=
NOTION_DB_DAILY_STANDUP=
NOTION_DB_LAUNCHES=

# --- Optional cache control ---
# Force fresh data per request (default: 60 seconds ISR).
# DASHBOARD_REVALIDATE=0
